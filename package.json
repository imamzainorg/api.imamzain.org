{
  "name": "api.imamzain.org",
  "version": "1.0.0",
  "description": "REST API for ImamZain.org",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node -P tsconfig.base.json prisma/seed.ts",
    "prisma:seed-content": "ts-node -P tsconfig.base.json prisma/seed-content.ts",
    "prisma:hydrate-media": "ts-node -P tsconfig.base.json prisma/hydrate-media.ts",
    "prisma:backfill-variants": "ts-node -P tsconfig.base.json prisma/backfill-media-variants.ts",
    "prisma:diagnose": "ts-node -P tsconfig.base.json prisma/seed-diagnose.ts",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:cov": "jest --coverage --config jest.config.js",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:all": "npm run test && npm run test:integration"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/throttler": "^6.5.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.0.0",
    "@sentry/nestjs": "^10.50.0",
    "@sentry/node": "^10.50.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.7.4",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^8.0.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.1",
    "jest": "^30.3.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
