# ── Database (Supabase) ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ── Server ──────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"
BCRYPT_ROUNDS=12

# ── Email (Hostinger SMTP) ──────────────────────────────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_USER="info@imamzain.org"
SMTP_PASS="your-mailbox-password"
SMTP_SECURE=true
EMAIL_FROM="ImamZain.org <info@imamzain.org>"
EMAIL_TO="info@imamzain.org"

# ── Twilio WhatsApp ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_TEMPLATE_SID=""

# ── Cloudflare R2 ───────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="imamzain-media"
R2_PUBLIC_BASE_URL="https://cdn.imamzain.org"
R2_UPLOAD_URL_TTL_SECONDS=900

# ── Sentry (production only) ────────────────────────────────────
SENTRY_DSN=""

# ── CORS ────────────────────────────────────────────────────────
# REQUIRED in production. Comma-separated list of explicit origins. Without
# this, the API refuses to boot in production rather than echoing the caller.
ALLOWED_ORIGINS="https://imamzain.org,https://cms.imamzain.com,https://app.imamzain.org"

# ── API docs (Scalar) ───────────────────────────────────────────
# "true" exposes /docs and /openapi.json publicly. Defaults to off in
# production to avoid leaking the full route surface to anonymous traffic.
EXPOSE_DOCS=""

# ── Newsletter unsubscribe ──────────────────────────────────────
# Server-side secret used to HMAC unsubscribe tokens returned at subscribe
# time. Falls back to JWT_SECRET when unset; set this explicitly if you ever
# rotate JWT_SECRET (rotating it would otherwise invalidate every existing
# unsubscribe link).
NEWSLETTER_UNSUBSCRIBE_SECRET=""

# Front-end unsubscribe page used to build {{unsubscribe_url}} substitution
# in outbound newsletter bodies. Defaults to https://imamzain.org/newsletter/unsubscribe.
NEWSLETTER_UNSUBSCRIBE_URL_BASE=""

# ── Public site (sitemap + RSS) ─────────────────────────────────
# Base URL the API emits when generating sitemap.xml / rss/posts.xml entries.
# Defaults to https://imamzain.org if unset. Public-facing post URLs are
# built as `${PUBLIC_SITE_URL}/{lang}/posts/{slug}`.
PUBLIC_SITE_URL=""

# Title shown in the RSS <channel><title> element. Defaults to
# "Imam Zain Foundation".
PUBLIC_SITE_NAME=""

# ── YouTube Data API ─────────────────────────────────────────────
# Powers the local YouTube mirror that the public /youtube/* endpoints
# and the homepage aggregator read from. A background cron syncs the
# channel's videos + playlists every 6 hours. If unset, sync is skipped
# silently — the homepage just returns an empty videos array.
#
# Get a key from console.cloud.google.com → enable "YouTube Data API
# v3" → restrict the key to that one API for safety. Quota is generous
# (10k units/day default); the sync uses ~10–20 units per run, so a
# tight margin is fine.
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""
