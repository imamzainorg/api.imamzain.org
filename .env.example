# ── Database (Supabase) ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ── Server ──────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"
BCRYPT_ROUNDS=12

# ── Email (Hostinger SMTP) ──────────────────────────────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_USER="info@imamzain.org"
SMTP_PASS="your-mailbox-password"
SMTP_SECURE=true
EMAIL_FROM="ImamZain.org <info@imamzain.org>"
EMAIL_TO="info@imamzain.org"

# ── Twilio WhatsApp ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_TEMPLATE_SID=""

# ── Cloudflare R2 ───────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="imamzain-media"
R2_PUBLIC_BASE_URL="https://cdn.imamzain.org"
R2_UPLOAD_URL_TTL_SECONDS=900

# ── Sentry (production only) ────────────────────────────────────
SENTRY_DSN=""

# ── CORS ────────────────────────────────────────────────────────
# REQUIRED in production. Comma-separated list of explicit origins. Without
# this, the API refuses to boot in production rather than echoing the caller.
ALLOWED_ORIGINS="https://imamzain.org,https://cms.imamzain.com,https://app.imamzain.org"

# ── API docs (Scalar) ───────────────────────────────────────────
# "true" exposes /docs and /openapi.json publicly. Defaults to off in
# production to avoid leaking the full route surface to anonymous traffic.
EXPOSE_DOCS=""

# ── Newsletter unsubscribe ──────────────────────────────────────
# Server-side secret used to HMAC unsubscribe tokens returned at subscribe
# time. Falls back to JWT_SECRET when unset; set this explicitly if you ever
# rotate JWT_SECRET (rotating it would otherwise invalidate every existing
# unsubscribe link).
NEWSLETTER_UNSUBSCRIBE_SECRET=""

# Front-end unsubscribe page used to build {{unsubscribe_url}} substitution
# in outbound newsletter bodies. Defaults to https://imamzain.org/newsletter/unsubscribe.
NEWSLETTER_UNSUBSCRIBE_URL_BASE=""

# ── Contest ─────────────────────────────────────────────────────
# Secret used to HMAC contest attempt tokens. Falls back to JWT_SECRET when
# unset; set it explicitly if you ever rotate JWT_SECRET (rotation would
# otherwise invalidate every in-flight contest attempt).
CONTEST_ATTEMPT_SECRET=""

# ── Seed (prisma:seed) ──────────────────────────────────────────
# Bootstrap super-admin credentials. If SEED_ADMIN_PASSWORD is unset, the
# seed skips user creation with a warning. Username defaults to "superadmin".
SEED_ADMIN_USERNAME=""
SEED_ADMIN_PASSWORD=""

# ── Ops ─────────────────────────────────────────────────────────
# "true" disables all background cron ticks (newsletter sends, scheduled
# publishing, YouTube sync, cleanup jobs) for this process. Set automatically
# by the operator scripts (upload-missing-r2, reconcile-audios,
# backfill-media-variants) so maintenance runs never execute production ticks.
DISABLE_CRON=""

# ── Public site (sitemap + RSS) ─────────────────────────────────
# Base URL the API emits when generating sitemap.xml / rss/posts.xml entries.
# Defaults to https://imamzain.org if unset. Public-facing post URLs are
# built as `${PUBLIC_SITE_URL}/{lang}/posts/{slug}`.
PUBLIC_SITE_URL=""

# Title shown in the RSS <channel><title> element. Defaults to
# "Imam Zain Foundation".
PUBLIC_SITE_NAME=""

# ── Redis (optional, multi-instance deployments) ────────────────
# When set, enables (a) a shared throttler counter across processes
# (otherwise each instance has its own bucket and the 1000/15min global
# ceiling effectively becomes 1000×N), and (b) pub/sub-driven JWT cache
# invalidation so a password change / admin reset on one instance clears
# the user's cached row on every other instance within milliseconds.
#
# Leave UNSET for single-instance prod and dev — both features fall back
# to in-process state with no behavioural difference at one instance.
#
# Format: redis://[username:password@]host:port[/db]
# TLS:    rediss://...
#
# If set but Redis is briefly unreachable, the API still boots; ioredis
# retries with exponential backoff and the affected features degrade
# gracefully until reconnection.
REDIS_URL=""

# ── YouTube Data API ─────────────────────────────────────────────
# Powers the local YouTube mirror that the public /youtube/* endpoints
# and the homepage aggregator read from. A background cron syncs the
# channel's videos + playlists every 6 hours. If unset, sync is skipped
# silently — the homepage just returns an empty videos array.
#
# Get a key from console.cloud.google.com → enable "YouTube Data API
# v3" → restrict the key to that one API for safety. Quota is generous
# (10k units/day default); the sync uses ~10–20 units per run, so a
# tight margin is fine.
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""
