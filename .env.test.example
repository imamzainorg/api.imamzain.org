# Copy this file to .env.test and fill in your values.
# .env.test is loaded automatically by jest.integration.config.js via test/load-env.ts.
# Never commit .env.test — it contains credentials.

# ─── Required ────────────────────────────────────────────────────────────────

# Point to a dedicated TEST database — NOT your production or development DB.
# Integration tests call deleteMany() on several tables before every test.
# Apply the schema first: npx prisma db push --skip-generate
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/imamzain_test

# ─── Optional (sensible defaults are used if omitted) ─────────────────────

# Low bcrypt cost keeps integration tests fast (4 rounds ≈ instant; 12 ≈ 300 ms each)
BCRYPT_ROUNDS=4

# Any string works here — integration tests don't verify JWT expiry
JWT_SECRET=test-only-secret-not-for-production
