generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model academic_paper_categories {
  id                                   String                                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                           DateTime                               @default(now()) @db.Timestamptz(6)
  deleted_at                           DateTime?                              @db.Timestamptz(6)
  academic_paper_category_translations academic_paper_category_translations[]
  academic_papers                      academic_papers[]
}

model academic_paper_category_translations {
  category_id               String                    @db.Uuid
  lang                      String                    @db.Char(2)
  title                     String
  slug                      String
  description               String?
  academic_paper_categories academic_paper_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages                 languages                 @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@id([category_id, lang])
  @@unique([lang, slug])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model academic_paper_translations {
  paper_id          String          @db.Uuid
  lang              String          @db.Char(2)
  title             String
  abstract          String?
  authors           String[]        @default([])
  keywords          String[]        @default([])
  publication_venue String?
  page_count        Int?
  is_default        Boolean         @default(false)
  languages         languages       @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)
  academic_papers   academic_papers @relation(fields: [paper_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([paper_id, lang])
}

model academic_papers {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id                 String                        @db.Uuid
  published_year              String?
  pdf_url                     String?
  uploaded_by                 String?                       @db.Uuid
  created_at                  DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime                      @default(now()) @db.Timestamptz(6)
  deleted_at                  DateTime?                     @db.Timestamptz(6)
  academic_paper_translations academic_paper_translations[]
  academic_paper_categories   academic_paper_categories     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                       users?                        @relation(fields: [uploaded_by], references: [id], onUpdate: NoAction)

  @@index([category_id], map: "idx_academic_papers_category")
  @@index([uploaded_by], map: "idx_academic_papers_uploaded")
}

model audit_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?  @db.Uuid
  action        String
  resource_type String
  resource_id   String?  @db.Uuid
  changes       Json?
  ip_address    String?  @db.Inet
  user_agent    String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  users         users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([action], map: "idx_audit_logs_action")
  @@index([created_at(sort: Desc)], map: "idx_audit_logs_created_at")
  @@index([resource_type, resource_id], map: "idx_audit_logs_resource")
  @@index([user_id], map: "idx_audit_logs_user_id")
}

model book_categories {
  id                         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  deleted_at                 DateTime?                    @db.Timestamptz(6)
  book_category_translations book_category_translations[]
  books                      books[]
}

model book_category_translations {
  category_id     String          @db.Uuid
  lang            String          @db.Char(2)
  title           String
  slug            String
  description     String?
  book_categories book_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages       languages       @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@id([category_id, lang])
  @@unique([lang, slug])
}

model book_translations {
  book_id     String    @db.Uuid
  lang        String    @db.Char(2)
  title       String
  author      String?
  publisher   String?
  description String?
  series      String?
  is_default  Boolean   @default(false)
  books       books     @relation(fields: [book_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages   languages @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@id([book_id, lang])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model books {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id       String              @db.Uuid
  cover_image_id    String              @db.Uuid
  isbn              String?             @unique
  pages             Int?
  publish_year      String?
  part_number       Int?
  parts             Int?
  views             BigInt              @default(0)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  added_by          String?             @db.Uuid
  deleted_at        DateTime?           @db.Timestamptz(6)
  book_translations book_translations[]
  users             users?              @relation(fields: [added_by], references: [id], onUpdate: NoAction)
  book_categories   book_categories     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  media             media               @relation(fields: [cover_image_id], references: [id], onUpdate: NoAction)

  @@index([added_by], map: "idx_books_added_by")
  @@index([category_id], map: "idx_books_category")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contact_submissions {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String         @db.Citext
  country      String?        @db.Char(2)
  message      String
  status       contact_status @default(NEW)
  submitted_at DateTime       @default(now()) @db.Timestamptz(6)
  responded_at DateTime?      @db.Timestamptz(6)
  responded_by String?        @db.Uuid
  notes        String?
  deleted_at   DateTime?      @db.Timestamptz(6)
  users        users?         @relation(fields: [responded_by], references: [id], onUpdate: NoAction)

  @@index([responded_by], map: "idx_contact_responded_by")
  @@index([status], map: "idx_contact_status")
}

model gallery_categories {
  id                            String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                    DateTime                        @default(now()) @db.Timestamptz(6)
  deleted_at                    DateTime?                       @db.Timestamptz(6)
  gallery_category_translations gallery_category_translations[]
  gallery_images                gallery_images[]
}

model gallery_category_translations {
  category_id        String             @db.Uuid
  lang               String             @db.Char(2)
  title              String
  slug               String
  description        String?
  gallery_categories gallery_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages          languages          @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@id([category_id, lang])
  @@unique([lang, slug])
}

model gallery_image_translations {
  media_id       String         @db.Uuid
  lang           String         @db.Char(2)
  title          String
  description    String?
  languages      languages      @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)
  gallery_images gallery_images @relation(fields: [media_id], references: [media_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([media_id, lang])
}

model gallery_images {
  media_id                   String                       @id @db.Uuid
  category_id                String?                      @db.Uuid
  taken_at                   DateTime?                    @db.Date
  author                     String?
  tags                       String[]                     @default([])
  locations                  String[]                     @default([])
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  added_by                   String?                      @db.Uuid
  deleted_at                 DateTime?                    @db.Timestamptz(6)
  gallery_image_translations gallery_image_translations[]
  users                      users?                       @relation(fields: [added_by], references: [id], onUpdate: NoAction)
  gallery_categories         gallery_categories?          @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  media                      media                        @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([added_by], map: "idx_gallery_images_added_by")
  @@index([category_id], map: "idx_gallery_images_category")
  @@index([locations], map: "idx_gallery_images_locations_gin", type: Gin)
  @@index([tags], map: "idx_gallery_images_tags_gin", type: Gin)
  @@index([taken_at], map: "idx_gallery_images_taken_at")
}

model languages {
  code                                 String                                 @id @db.Char(2)
  name                                 String
  native_name                          String
  is_active                            Boolean                                @default(true)
  deleted_at                           DateTime?                              @db.Timestamptz(6)
  academic_paper_category_translations academic_paper_category_translations[]
  academic_paper_translations          academic_paper_translations[]
  book_category_translations           book_category_translations[]
  book_translations                    book_translations[]
  gallery_category_translations        gallery_category_translations[]
  gallery_image_translations           gallery_image_translations[]
  permission_translations              permission_translations[]
  post_category_translations           post_category_translations[]
  post_translations                    post_translations[]
  role_translations                    role_translations[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model media {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename            String
  alt_text            String?
  url                 String              @unique
  mime_type           String
  file_size           BigInt
  width               Int?
  height              Int?
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  uploaded_by         String?             @db.Uuid
  books               books[]
  gallery_images      gallery_images?
  users               users?              @relation(fields: [uploaded_by], references: [id], onUpdate: NoAction)
  media_variants      media_variants[]
  post_attachments    post_attachments[]
  post_translation_og post_translations[] @relation("post_translation_og_image")
  posts               posts?

  @@index([uploaded_by], map: "idx_media_uploaded_by")
}

model media_variants {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  media_id   String   @db.Uuid
  width      Int
  url        String
  file_size  BigInt
  format     String   @default("webp")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  media      media    @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([media_id, width])
  @@index([media_id], map: "idx_media_variants_media_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model newsletter_subscribers {
  id                             String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                          String                           @unique @db.Citext
  is_active                      Boolean                          @default(true)
  subscribed_at                  DateTime                         @default(now()) @db.Timestamptz(6)
  unsubscribed_at                DateTime?                        @db.Timestamptz(6)
  deleted_at                     DateTime?                        @db.Timestamptz(6)
  newsletter_campaign_recipients newsletter_campaign_recipients[]
}

model permission_translations {
  permission_id String      @db.Uuid
  lang          String      @db.Char(2)
  title         String
  description   String?
  languages     languages   @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([permission_id, lang])
}

model permissions {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @unique
  permission_translations permission_translations[]
  role_permissions        role_permissions[]
}

model post_attachments {
  post_id       String @db.Uuid
  media_id      String @db.Uuid
  display_order Int    @default(0)
  media         media  @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts         posts  @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, media_id])
  @@index([post_id, display_order], map: "idx_post_attachments_order")
  @@index([post_id], map: "idx_post_attachments_post")
}

model post_categories {
  id                         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  deleted_at                 DateTime?                    @db.Timestamptz(6)
  post_category_translations post_category_translations[]
  posts                      posts[]
}

model post_category_translations {
  category_id     String          @db.Uuid
  lang            String          @db.Char(2)
  title           String
  slug            String
  description     String?
  post_categories post_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages       languages       @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@id([category_id, lang])
  @@unique([lang, slug])
}

model post_translations {
  post_id          String    @db.Uuid
  lang             String    @db.Char(2)
  title            String
  summary          String?
  body             String
  slug             String
  is_default       Boolean   @default(false)
  meta_title       String?
  meta_description String?
  og_image_id      String?   @db.Uuid
  languages        languages @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)
  og_image         media?    @relation("post_translation_og_image", fields: [og_image_id], references: [id], onUpdate: NoAction)
  posts            posts     @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, lang])
  @@unique([lang, slug])
  @@index([og_image_id], map: "idx_post_translations_og_image")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model posts {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id       String              @db.Uuid
  cover_image_id    String?             @unique @db.Uuid
  published_at      DateTime?           @db.Timestamptz(6)
  is_published      Boolean             @default(false)
  is_featured       Boolean             @default(false)
  views             BigInt              @default(0)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  created_by        String?             @db.Uuid
  deleted_at        DateTime?           @db.Timestamptz(6)
  post_attachments  post_attachments[]
  post_translations post_translations[]
  post_categories   post_categories     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  media             media?              @relation(fields: [cover_image_id], references: [id], onUpdate: NoAction)
  users             users?              @relation(fields: [created_by], references: [id], onUpdate: NoAction)

  @@index([category_id], map: "idx_posts_category")
  @@index([created_by], map: "idx_posts_created_by")
  @@index([is_published, published_at], map: "idx_posts_published")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model proxy_visit_requests {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  phone        String?
  country      String?            @db.Char(2)
  status       proxy_visit_status @default(PENDING)
  submitted_at DateTime           @default(now()) @db.Timestamptz(6)
  processed_at DateTime?          @db.Timestamptz(6)
  processed_by String?            @db.Uuid
  notes        String?
  deleted_at   DateTime?          @db.Timestamptz(6)
  users        users?             @relation(fields: [processed_by], references: [id], onUpdate: NoAction)

  @@index([processed_by], map: "idx_proxy_visit_processed_by")
  @@index([status], map: "idx_proxy_visit_status")
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model role_translations {
  role_id     String    @db.Uuid
  lang        String    @db.Char(2)
  title       String
  description String?
  languages   languages @relation(fields: [lang], references: [code], onDelete: Cascade, onUpdate: NoAction)
  roles       roles     @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, lang])
}

model roles {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String              @unique
  role_permissions  role_permissions[]
  role_translations role_translations[]
  user_roles        user_roles[]
}

model user_roles {
  user_id String @db.Uuid
  role_id String @db.Uuid
  roles   roles  @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, role_id])
}

model users {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username              String                  @unique
  password_hash         String
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  deleted_at            DateTime?               @db.Timestamptz(6)
  token_version         Int                     @default(1)
  academic_papers       academic_papers[]
  audit_logs            audit_logs[]
  books                 books[]
  contact_submissions   contact_submissions[]
  gallery_images        gallery_images[]
  media                 media[]
  newsletter_campaigns  newsletter_campaigns[]
  pending_media_uploads pending_media_uploads[]
  posts                 posts[]
  proxy_visit_requests  proxy_visit_requests[]
  refresh_tokens        refresh_tokens[]
  site_settings_updated site_settings[]         @relation("site_settings_updated_by")
  user_roles            user_roles[]
}

model site_settings {
  key         String            @id
  value       String
  type        site_setting_type @default(string)
  description String?
  is_public   Boolean           @default(false)
  updated_at  DateTime          @default(now()) @db.Timestamptz(6)
  updated_by  String?           @db.Uuid
  users       users?            @relation("site_settings_updated_by", fields: [updated_by], references: [id], onUpdate: NoAction)
}

model qutuf_sajjadiya_contest_attempts {
  id                           String                            @id(map: "contest_entries_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                         String?
  email                        String?
  started_at                   DateTime?                         @db.Timestamptz(6)
  submitted_at                 DateTime?                         @default(now()) @db.Timestamptz(6)
  ip                           String?
  user_agent                   String?
  final_score                  Int?
  phone                        String?
  qutufSajjadiyaContestAnswers qutuf_sajjadiya_contest_answers[]
}

model qutuf_sajjadiya_contest_questions {
  id                              String                            @id(map: "contest_questions_pkey")
  question                        String
  option_a                        String
  option_b                        String
  option_c                        String
  option_d                        String
  correct_answer                  String
  qutuf_sajjadiya_contest_answers qutuf_sajjadiya_contest_answers[]
}

model qutuf_sajjadiya_contest_answers {
  id                                String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id                        String                            @db.Uuid
  question_id                       String
  selected                          String
  is_correct                        Boolean
  attempt                           qutuf_sajjadiya_contest_attempts  @relation(fields: [attempt_id], references: [id], onDelete: Cascade, map: "qutuf_answers_attempt_id_fkey")
  qutuf_sajjadiya_contest_questions qutuf_sajjadiya_contest_questions @relation(fields: [question_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "qutuf_answers_question_id_fkey")

  @@unique([attempt_id, question_id], map: "qutuf_answers_unique_attempt_question")
  @@index([attempt_id], map: "idx_qutuf_answers_attempt_id")
}

model pending_media_uploads {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String   @unique(map: "uq_pending_media_key")
  requested_by String?  @db.Uuid
  requested_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at   DateTime @default(dbgenerated("(now() + '00:15:00'::interval)")) @db.Timestamptz(6)
  users        users?   @relation(fields: [requested_by], references: [id], onUpdate: NoAction)

  @@index([expires_at], map: "idx_pending_media_expires")
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique(map: "uq_refresh_tokens_hash")
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_refresh_tokens_expires_at")
  @@index([user_id], map: "idx_refresh_tokens_user_id")
}

model newsletter_campaign_recipients {
  campaign_id            String                 @db.Uuid
  subscriber_id          String                 @db.Uuid
  sent_at                DateTime?              @db.Timestamptz(6)
  failed_at              DateTime?              @db.Timestamptz(6)
  error_message          String?
  newsletter_campaigns   newsletter_campaigns   @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  newsletter_subscribers newsletter_subscribers @relation(fields: [subscriber_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([campaign_id, subscriber_id])
}

model newsletter_campaigns {
  id                             String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject                        String
  body_html                      String
  status                         newsletter_campaign_status       @default(draft)
  scheduled_at                   DateTime?                        @db.Timestamptz(6)
  sent_at                        DateTime?                        @db.Timestamptz(6)
  recipient_count                Int?
  delivered_count                Int                              @default(0)
  failed_count                   Int                              @default(0)
  source_resource_type           String?
  source_resource_id             String?                          @db.Uuid
  created_by                     String?                          @db.Uuid
  created_at                     DateTime                         @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime                         @default(now()) @db.Timestamptz(6)
  newsletter_campaign_recipients newsletter_campaign_recipients[]
  users                          users?                           @relation(fields: [created_by], references: [id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_newsletter_campaigns_created_at")
  @@index([status], map: "idx_newsletter_campaigns_status")
}

enum site_setting_type {
  string
  number
  boolean
  json
}

enum contact_status {
  NEW
  RESPONDED
  SPAM
}

enum proxy_visit_status {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum newsletter_campaign_status {
  draft
  scheduled
  sending
  sent
  failed
  cancelled
}
